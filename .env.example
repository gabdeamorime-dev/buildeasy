# Copiez ce fichier en .env et remplissez depuis Supabase → Project Settings → API
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_publishable_ou_anon

# Comptes démo locaux sans Supabase — false en production (les raccourcis démo cloud restent visibles)
VITE_DEMO_MODE=false

# Stripe (Dashboard → Developers → API keys + scripts/setup-stripe.mjs pour les price IDs)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_STARTER=price_...
VITE_STRIPE_PRICE_PRO=price_...
VITE_STRIPE_PRICE_ENTREPRISE=price_...

# Next.js uniquement
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=votre_cle_publishable

# Uniquement pour scripts/seed-demo-users.mjs (ne jamais exposer côté client)
# Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Apple Developer — Team ID (10 caractères) pour signature iOS
# https://developer.apple.com/account → Membership
APPLE_TEAM_ID=
