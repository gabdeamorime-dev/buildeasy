{
  "name": "buildeasy",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/generate-sw.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed:users": "node scripts/seed-demo-users.mjs",
    "create:client": "node scripts/create-client.mjs",
    "stripe:setup": "node scripts/setup-stripe.mjs",
    "stripe:deploy": "bash scripts/deploy-stripe.sh",
    "stripe:complete": "node scripts/complete-stripe-setup.mjs",
    "stripe:finish": "node scripts/stripe-finish-setup.mjs",
    "stripe:verify": "node scripts/verify-stripe-setup.mjs",
    "configure:prod": "node scripts/configure-production.mjs",
    "configure:prod:deploy": "node scripts/configure-production.mjs --deploy",
    "configure:checklist": "node scripts/print-config-checklist.mjs",
    "vercel:deploy": "node scripts/vercel-deploy.mjs",
    "security:audit": "node scripts/security-audit.mjs",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "deploy": "node scripts/vercel-deploy.mjs",
    "fix:vercel-domain": "node scripts/fix-vercel-domain.mjs",
    "diagnose:vercel": "node scripts/diagnose-vercel.mjs",
    "assets:generate": "node scripts/generate-store-assets.mjs && npx capacitor-assets generate --assetPath assets --iconBackgroundColor '#2563EB' --iconBackgroundColorDark '#1D4ED8' --splashBackgroundColor '#2563EB' --splashBackgroundColorDark '#1D4ED8'",
    "configure:ios": "node scripts/configure-ios.mjs",
    "prepare:ios": "bash scripts/prepare-ios.sh",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "build:ios": "npm run cap:sync && xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Release -destination 'generic/platform=iOS' -archivePath build/BuildEasy.xcarchive archive CODE_SIGNING_ALLOWED=NO",
    "build:android": "npm run cap:sync && cd android && ./gradlew assembleRelease bundleRelease",
    "build:store": "bash scripts/build-store.sh",
    "open:ios": "open ios/App/App.xcodeproj",
    "open:android": "open -a 'Android Studio' android",
    "build:mobile": "npm run build:ios && npm run build:android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
